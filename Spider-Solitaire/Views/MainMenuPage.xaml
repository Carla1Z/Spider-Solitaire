<?xml version="1.0" encoding="utf-8" ?>
<!--
    Pantalla principal / menú de inicio.
    Estética cottage core: fondo verde bosque, tipografía cálida, decoraciones naturales.
-->
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SpiderSolitaire.ViewModels"
    xmlns:converters="clr-namespace:SpiderSolitaire.Converters"
    x:Class="SpiderSolitaire.Views.MainMenuPage"
    x:DataType="vm:MainMenuViewModel"
    BackgroundColor="{StaticResource BackgroundPrimary}"
    Title="">

    <ContentPage.Resources>
        <converters:DifficultyToColorConverter x:Key="DifficultyColorConverter"/>
        <converters:BoolToOpacityConverter     x:Key="BoolOpacity"/>
    </ContentPage.Resources>

    <!-- Fondo con gradiente natural -->
    <Grid>

        <!-- ── Capa de fondo decorativa ─────────────────────────── -->
        <BoxView
            Color="{StaticResource BackgroundPrimary}"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"/>

        <!-- Decoración de hojas en las esquinas -->
        <Label
            Text="🌿" FontSize="60" Opacity="0.15"
            VerticalOptions="Start" HorizontalOptions="Start"
            Margin="10,20,0,0" Rotation="-20"/>
        <Label
            Text="🍃" FontSize="50" Opacity="0.12"
            VerticalOptions="Start" HorizontalOptions="End"
            Margin="0,15,10,0" Rotation="30"/>
        <Label
            Text="🌸" FontSize="40" Opacity="0.10"
            VerticalOptions="End" HorizontalOptions="Start"
            Margin="20,0,0,40" Rotation="15"/>
        <Label
            Text="🍂" FontSize="45" Opacity="0.12"
            VerticalOptions="End" HorizontalOptions="End"
            Margin="0,0,15,30" Rotation="-10"/>

        <!-- ── Contenido principal ───────────────────────────────── -->
        <ScrollView>
            <VerticalStackLayout
                Padding="30,60,30,40"
                Spacing="0"
                VerticalOptions="Center">

                <!-- ══ TÍTULO ══════════════════════════════════════ -->
                <VerticalStackLayout Spacing="8" Margin="0,0,0,50">

                    <!-- Emoji decorativo -->
                    <Label
                        Text="🕷️"
                        FontSize="56"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"/>

                    <!-- Título principal -->
                    <Label
                        Text="Spider"
                        FontFamily="{StaticResource FontDecorative}"
                        FontSize="52"
                        TextColor="{StaticResource AccentGold}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        CharacterSpacing="3"/>

                    <!-- Subtítulo -->
                    <Label
                        Text="Solitaire"
                        FontFamily="{StaticResource FontTitle}"
                        FontSize="28"
                        TextColor="{StaticResource TextOnDark}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Opacity="0.85"
                        CharacterSpacing="8"/>

                    <!-- Separador decorativo -->
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="8"
                        Margin="0,12,0,0">
                        <BoxView
                            Color="{StaticResource AccentGold}"
                            HeightRequest="1"
                            WidthRequest="60"
                            VerticalOptions="Center"
                            Opacity="0.6"/>
                        <Label
                            Text="🌿"
                            FontSize="16"
                            VerticalOptions="Center"/>
                        <BoxView
                            Color="{StaticResource AccentGold}"
                            HeightRequest="1"
                            WidthRequest="60"
                            VerticalOptions="Center"
                            Opacity="0.6"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- ══ SELECCIÓN DE DIFICULTAD ══════════════════════════════ -->
                <VerticalStackLayout Spacing="14" Margin="0,0,0,40">

                    <Label
        Text="Elige tu aventura"
        FontFamily="{StaticResource FontTitle}"
        FontSize="16"
        TextColor="{StaticResource TextOnDark}"
        HorizontalOptions="Center"
        HorizontalTextAlignment="Center"
        Opacity="0.7"
        CharacterSpacing="2"
        TextTransform="Uppercase"/>

                    <!-- Opción 1: Un Palo -->
                    <Border
        x:Name="BorderOneSuit"
        StrokeShape="RoundRectangle 14,14,14,14"
        StrokeThickness="1.5"
        Stroke="{StaticResource AccentMoss}"
        BackgroundColor="{StaticResource BackgroundSecondary}"
        Padding="20,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Command="{Binding SelectDifficultyCommand}"
                CommandParameter="0"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="🌿 Un Palo"
                       FontFamily="{StaticResource FontBodyBold}"
                       FontSize="15"
                       TextColor="{StaticResource TextOnDark}"/>
                                <Label Text="Ideal para principiantes"
                       FontFamily="{StaticResource FontBody}"
                       FontSize="12"
                       TextColor="{StaticResource TextOnDark}"
                       Opacity="0.65"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="✓"
                   FontSize="20"
                   TextColor="{StaticResource AccentGold}"
                   VerticalOptions="Center"
                   IsVisible="{Binding SelectedDifficulty,
                       Converter={StaticResource IsOneSuitConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Opción 2: Dos Palos -->
                    <Border
        x:Name="BorderTwoSuits"
        StrokeShape="RoundRectangle 14,14,14,14"
        StrokeThickness="1.5"
        Stroke="{StaticResource AccentMoss}"
        BackgroundColor="{StaticResource BackgroundSecondary}"
        Padding="20,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Command="{Binding SelectDifficultyCommand}"
                CommandParameter="1"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="🌸 Dos Palos"
                       FontFamily="{StaticResource FontBodyBold}"
                       FontSize="15"
                       TextColor="{StaticResource TextOnDark}"/>
                                <Label Text="Desafío moderado"
                       FontFamily="{StaticResource FontBody}"
                       FontSize="12"
                       TextColor="{StaticResource TextOnDark}"
                       Opacity="0.65"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="✓"
                   FontSize="20"
                   TextColor="{StaticResource AccentGold}"
                   VerticalOptions="Center"
                   IsVisible="{Binding SelectedDifficulty,
                       Converter={StaticResource IsTwoSuitsConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Opción 3: Cuatro Palos -->
                    <Border
        x:Name="BorderFourSuits"
        StrokeShape="RoundRectangle 14,14,14,14"
        StrokeThickness="1.5"
        Stroke="{StaticResource AccentMoss}"
        BackgroundColor="{StaticResource BackgroundSecondary}"
        Padding="20,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                Command="{Binding SelectDifficultyCommand}"
                CommandParameter="2"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="🍂 Cuatro Palos"
                       FontFamily="{StaticResource FontBodyBold}"
                       FontSize="15"
                       TextColor="{StaticResource TextOnDark}"/>
                                <Label Text="Para expertos"
                       FontFamily="{StaticResource FontBody}"
                       FontSize="12"
                       TextColor="{StaticResource TextOnDark}"
                       Opacity="0.65"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="✓"
                   FontSize="20"
                   TextColor="{StaticResource AccentGold}"
                   VerticalOptions="Center"
                   IsVisible="{Binding SelectedDifficulty,
                       Converter={StaticResource IsFourSuitsConverter}}"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ══ BOTONES DE ACCIÓN ═════════════════════════════ -->
                <VerticalStackLayout Spacing="14">

                    <!-- Botón Nueva Partida -->
                    <Button
                        Text="🌱  Nueva Partida"
                        Command="{Binding NewGameCommand}"
                        FontFamily="{StaticResource FontBodyBold}"
                        FontSize="17"
                        TextColor="{StaticResource TextOnDark}"
                        BackgroundColor="{StaticResource ButtonSecondary}"
                        CornerRadius="14"
                        HeightRequest="54"
                        Shadow="{Shadow Brush={StaticResource CardShadow},
                                        Offset='0,3', Radius=6, Opacity=0.3}"/>

                    <!-- Botón Continuar (visible solo si hay partida guardada) -->
                    <Button
                        Text="🍃  Continuar Partida"
                        Command="{Binding ContinueGameCommand}"
                        IsVisible="{Binding HasSavedGame}"
                        FontFamily="{StaticResource FontBody}"
                        FontSize="16"
                        TextColor="{StaticResource TextOnDark}"
                        BackgroundColor="{StaticResource ButtonPrimary}"
                        CornerRadius="14"
                        HeightRequest="50"/>

                    <!-- Indicador de carga -->
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="{StaticResource AccentGold}"
                        HorizontalOptions="Center"
                        Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- ══ PIE DE PÁGINA ═════════════════════════════════ -->
                <Label
                    Text="🌸 Un rincón tranquilo entre hojas y cartas 🌸"
                    FontFamily="{StaticResource FontBody}"
                    FontSize="12"
                    TextColor="{StaticResource TextOnDark}"
                    Opacity="0.4"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Margin="0,40,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>