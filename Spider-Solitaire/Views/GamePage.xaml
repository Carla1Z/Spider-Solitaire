<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SpiderSolitaire.ViewModels"
    xmlns:dto="clr-namespace:SpiderSolitaire.DTOs"
    xmlns:controls="clr-namespace:SpiderSolitaire.Controls"
    x:Class="SpiderSolitaire.Views.GamePage"
    x:DataType="vm:GameViewModel"
    x:Name="ThisPage"
    BackgroundColor="{StaticResource TableFelt}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ BARRA SUPERIOR ════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            BackgroundColor="{StaticResource BackgroundPrimary}"
            StrokeThickness="0"
            Padding="10,8">

            <Grid ColumnDefinitions="40,*,*,*,60">

                <!-- Botón Menú -->
                <Button
                    Grid.Column="0"
                    Text="🏡"
                    FontSize="18"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextOnDark}"
                    Command="{Binding BackToMenuCommand}"
                    Padding="0"
                    MinimumWidthRequest="40"
                    HeightRequest="36"/>

                <!-- Puntaje -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="0">
                    <Label Text="PUNTAJE" Style="{StaticResource StatLabelStyle}"/>
                    <Label Text="{Binding Score}" Style="{StaticResource StatValueStyle}"/>
                </VerticalStackLayout>

                <!-- Movimientos -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="0">
                    <Label Text="MOVS" Style="{StaticResource StatLabelStyle}"/>
                    <Label Text="{Binding Moves}" Style="{StaticResource StatValueStyle}"/>
                </VerticalStackLayout>

                <!-- Tiempo -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="0">
                    <Label Text="TIEMPO" Style="{StaticResource StatLabelStyle}"/>
                    <Label Text="{Binding ElapsedTime}" Style="{StaticResource StatValueStyle}"/>
                </VerticalStackLayout>

                <!-- Secuencias -->
                <Label
                    Grid.Column="4"
                    Text="{Binding CompletedSequences, StringFormat='{0}/8 🃏'}"
                    FontFamily="{StaticResource FontBodyBold}"
                    FontSize="13"
                    TextColor="{StaticResource AccentGold}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <!-- ══ TABLERO ═══════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" Orientation="Both">
            <Grid
                x:Name="BoardGrid"
                Padding="4,8,4,8"
                VerticalOptions="Start"
                HorizontalOptions="Fill">
                <!--
                    Las columnas se generan en code-behind con
                    ColumnViews dinámicos — evita RelativeSource
                    dentro de DataTemplate que crashea en Android.
                -->
            </Grid>
        </ScrollView>

        <!-- ══ BARRA INFERIOR ════════════════════════════════════ -->
        <Border
            Grid.Row="2"
            BackgroundColor="{StaticResource BackgroundPrimary}"
            StrokeThickness="0"
            Padding="12,8">

            <Grid ColumnDefinitions="*,Auto,Auto,Auto">

                <!-- Dificultad -->
                <Label
                    Grid.Column="0"
                    Text="{Binding DifficultyLabel}"
                    FontFamily="{StaticResource FontBody}"
                    FontSize="11"
                    TextColor="{StaticResource TextOnDark}"
                    Opacity="0.6"
                    VerticalOptions="Center"/>

                <!-- Deshacer -->
                <Button
                    Grid.Column="1"
                    Text="↩ Deshacer"
                    Command="{Binding UndoCommand}"
                    BackgroundColor="{StaticResource ButtonPrimary}"
                    TextColor="{StaticResource TextOnDark}"
                    FontFamily="{StaticResource FontBody}"
                    FontSize="13"
                    CornerRadius="10"
                    HeightRequest="40"
                    Margin="4,0"
                    Opacity="{Binding CanUndo, Converter={StaticResource BoolOpacity}}"/>

                <!-- Repartir -->
                <Button
                    Grid.Column="2"
                    Text="{Binding StockRemaining, StringFormat='🃏 Repartir ({0})'}"
                    Command="{Binding DealCommand}"
                    BackgroundColor="{StaticResource ButtonSecondary}"
                    TextColor="{StaticResource TextOnDark}"
                    FontFamily="{StaticResource FontBody}"
                    FontSize="13"
                    CornerRadius="10"
                    HeightRequest="40"
                    Margin="4,0"
                    Opacity="{Binding CanDeal, Converter={StaticResource BoolOpacity}}"/>

                <!-- Reiniciar -->
                <Button
                    Grid.Column="3"
                    Text="🔄"
                    Command="{Binding RestartCommand}"
                    BackgroundColor="{StaticResource ButtonDanger}"
                    TextColor="{StaticResource TextOnDark}"
                    FontSize="16"
                    CornerRadius="10"
                    HeightRequest="40"
                    WidthRequest="44"
                    Margin="4,0"/>
            </Grid>
        </Border>

        <!-- ══ OVERLAY FIN DE JUEGO ══════════════════════════════ -->
        <Grid
            Grid.RowSpan="3"
            IsVisible="{Binding IsGameOver}"
            BackgroundColor="{StaticResource OverlayDark}"
            ZIndex="99">

            <Border
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="{StaticResource CardFace}"
                StrokeShape="RoundRectangle 20,20,20,20"
                StrokeThickness="0"
                Padding="40,36"
                MinimumWidthRequest="280">

                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                    <Label
                        Text="{Binding HasWon, Converter={StaticResource WinLoseEmojiConverter}}"
                        FontSize="56"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="{Binding HasWon, Converter={StaticResource WinLoseTitleConverter}}"
                        FontFamily="{StaticResource FontDecorative}"
                        FontSize="32"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="{Binding Score, StringFormat='Puntaje final: {0}'}"
                        FontFamily="{StaticResource FontBody}"
                        FontSize="16"
                        TextColor="{StaticResource TextSecondary}"
                        HorizontalOptions="Center"/>

                    <BoxView Color="{StaticResource CardBorder}" HeightRequest="1" Margin="0,4"/>

                    <Button
                        Text="🌱  Jugar de Nuevo"
                        Command="{Binding NewGameCommand}"
                        BackgroundColor="{StaticResource ButtonSecondary}"
                        TextColor="{StaticResource TextOnDark}"
                        FontFamily="{StaticResource FontBodyBold}"
                        CornerRadius="12"
                        HeightRequest="46"/>

                    <Button
                        Text="🏡  Volver al Menú"
                        Command="{Binding BackToMenuCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        FontFamily="{StaticResource FontBody}"
                        CornerRadius="12"
                        HeightRequest="42"
                        BorderColor="{StaticResource CardBorder}"
                        BorderWidth="1"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>