<?xml version="1.0" encoding="utf-8" ?>
<!--
    Vista de una carta individual.
    Diseño cottage core: borde redondeado, colores beige/crema, tipografía Playfair.
-->
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:constants="clr-namespace:SpiderSolitaire.Constants"
    x:Class="SpiderSolitaire.Controls.CardView"
    x:Name="Root">

    <!-- Contenedor principal de la carta -->
    <Border
        x:Name="CardBorder"
        BackgroundColor="{StaticResource CardFace}"
        Stroke="{StaticResource CardBorder}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 6,6,6,6"
        Padding="3"
        Shadow="{Shadow Brush={StaticResource CardShadow}, Offset='2,2', Radius=4, Opacity=0.3}">

        <Grid>
            <!-- ══ CARA: carta boca arriba ══════════════════════════ -->
            <Grid x:Name="CardFaceContent" IsVisible="True">

                <!-- Valor y palo — esquina superior izquierda -->
                <StackLayout
                    VerticalOptions="Start"
                    HorizontalOptions="Start"
                    Spacing="0"
                    Margin="3,2,0,0">

                    <Label
                        x:Name="RankTopLabel"
                        Text="A"
                        FontFamily="{StaticResource FontCardRank}"
                        FontSize="12"
                        FontAttributes="Bold"
                        LineBreakMode="NoWrap"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        x:Name="SuitTopLabel"
                        Text="♠"
                        FontSize="10"
                        LineBreakMode="NoWrap"
                        HorizontalTextAlignment="Center"/>
                </StackLayout>

                <!-- Símbolo central del palo -->
                <Label
                    x:Name="CenterSuitLabel"
                    Text="♠"
                    FontSize="22"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>

                <!-- Valor y palo — esquina inferior derecha (rotado 180°) -->
                <StackLayout
                    VerticalOptions="End"
                    HorizontalOptions="End"
                    Spacing="0"
                    Margin="0,0,3,2"
                    Rotation="180">

                    <Label
                        x:Name="RankBottomLabel"
                        Text="A"
                        FontFamily="{StaticResource FontCardRank}"
                        FontSize="12"
                        FontAttributes="Bold"
                        LineBreakMode="NoWrap"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        x:Name="SuitBottomLabel"
                        Text="♠"
                        FontSize="10"
                        LineBreakMode="NoWrap"
                        HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Grid>

            <!-- ══ DORSO: carta boca abajo ══════════════════════════ -->
            <Grid
                x:Name="CardBackContent"
                IsVisible="False"
                BackgroundColor="{StaticResource CardBack}">

                <!-- Patrón decorativo cottage: pequeñas flores/hojas -->
                <Label
                    Text="🌿"
                    FontSize="18"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Opacity="0.6"/>

                <!-- Borde interior decorativo -->
                <Border
                    Margin="4"
                    BackgroundColor="Transparent"
                    Stroke="{StaticResource AccentGold}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 3,3,3,3"
                    Opacity="0.5"/>
            </Grid>
        </Grid>
    </Border>
</ContentView>