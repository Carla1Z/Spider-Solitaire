<?xml version="1.0" encoding="UTF-8" ?>
<!--
    App.xaml: recursos globales de la aplicación.
    Define la paleta de colores cottage core, tipografías y estilos base.
-->
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:SpiderSolitaire.Converters"
    x:Class="SpiderSolitaire.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ══════════════════════════════════════════════════════
                 PALETA DE COLORES — COTTAGE CORE
                 Tonos suaves de naturaleza: bosque, tierra, flores
            ══════════════════════════════════════════════════════ -->

            <!-- Fondos -->
            <Color x:Key="BackgroundPrimary">#2D4A2D</Color>
            <Color x:Key="BackgroundSecondary">#3A5C3A</Color>
            <Color x:Key="TableFelt">#4A7C59</Color>

            <!-- Cartas -->
            <Color x:Key="CardFace">#FAF3E8</Color>
            <Color x:Key="CardBack">#7B9E6B</Color>
            <Color x:Key="CardBorder">#C4A882</Color>
            <Color x:Key="CardShadow">#1A2E1A</Color>

            <!-- Texto -->
            <Color x:Key="TextPrimary">#3B2A1A</Color>
            <Color x:Key="TextSecondary">#6B5040</Color>
            <Color x:Key="TextOnDark">#F0E8D8</Color>
            <Color x:Key="TextRed">#C0392B</Color>
            <Color x:Key="TextBlack">#2C1810</Color>

            <!-- Botones -->
            <Color x:Key="ButtonPrimary">#8B7355</Color>
            <Color x:Key="ButtonSecondary">#6B8F5E</Color>
            <Color x:Key="ButtonAccent">#C4956A</Color>
            <Color x:Key="ButtonDanger">#B87070</Color>

            <!-- Highlights -->
            <Color x:Key="HighlightValid">#90C88A</Color>
            <Color x:Key="HighlightInvalid">#C88A8A</Color>
            <Color x:Key="HighlightSelect">#E8C97A</Color>

            <!-- Decorativos -->
            <Color x:Key="AccentGold">#D4A853</Color>
            <Color x:Key="AccentRose">#D4956A</Color>
            <Color x:Key="AccentMoss">#7A9E6A</Color>
            <Color x:Key="AccentBark">#8B6914</Color>

            <!-- Overlays -->
            <Color x:Key="OverlayDark">#CC1A2E1A</Color>
            <Color x:Key="OverlayLight">#99FAF3E8</Color>

            <!-- ══════════════════════════════════════════════════════
                 TIPOGRAFÍAS — Fuentes cottage core
                 Registradas en MauiProgram.cs
            ══════════════════════════════════════════════════════ -->
            <x:String x:Key="FontTitle">PlayfairDisplay</x:String>
            <x:String x:Key="FontTitleBold">PlayfairDisplay-Bold</x:String>
            <x:String x:Key="FontBody">Lato</x:String>
            <x:String x:Key="FontBodyBold">Lato-Bold</x:String>
            <x:String x:Key="FontDecorative">DancingScript</x:String>
            <x:String x:Key="FontCardRank">PlayfairDisplay-Bold</x:String>

            <!-- ══════════════════════════════════════════════════════
                 CONVERTERS GLOBALES
            ══════════════════════════════════════════════════════ -->
            <converters:BoolToOpacityConverter     x:Key="BoolOpacity"/>
            <converters:InverseBoolConverter       x:Key="InverseBoolConverter"/>
            <converters:WinLoseEmojiConverter      x:Key="WinLoseEmojiConverter"/>
            <converters:WinLoseTitleConverter      x:Key="WinLoseTitleConverter"/>
            <converters:DifficultyToColorConverter x:Key="DifficultyColorConverter"/>

            <!-- ══════════════════════════════════════════════════════
                 ESTILOS GLOBALES
            ══════════════════════════════════════════════════════ -->

            <!-- Estilo base para Label -->
            <Style TargetType="Label">
                <Setter Property="FontFamily"  Value="Lato"/>
                <Setter Property="TextColor"   Value="{StaticResource TextOnDark}"/>
                <Setter Property="FontSize"    Value="14"/>
            </Style>

            <!-- Estilo base para Button -->
            <Style TargetType="Button">
                <Setter Property="FontFamily"       Value="Lato-Bold"/>
                <Setter Property="CornerRadius"     Value="12"/>
                <Setter Property="BackgroundColor"  Value="{StaticResource ButtonPrimary}"/>
                <Setter Property="TextColor"        Value="{StaticResource TextOnDark}"/>
                <Setter Property="FontSize"         Value="15"/>
                <Setter Property="HeightRequest"    Value="48"/>
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal"/>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.8"/>
                                    <Setter Property="Scale"   Value="0.97"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <!-- Estilo para Border tipo card -->
            <Style x:Key="CardContainerStyle" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="{StaticResource CardFace}"/>
                <Setter Property="Stroke"           Value="{StaticResource CardBorder}"/>
                <Setter Property="StrokeThickness"  Value="1"/>
                <Setter Property="StrokeShape"      Value="RoundRectangle 8,8,8,8"/>
            </Style>

            <!-- Estilo para paneles de UI oscuros -->
            <Style x:Key="DarkPanelStyle" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="{StaticResource BackgroundPrimary}"/>
                <Setter Property="StrokeThickness"  Value="0"/>
                <Setter Property="Padding"          Value="16,12"/>
            </Style>

            <!-- Estilo para títulos decorativos -->
            <Style x:Key="DecorativeTitleStyle" TargetType="Label">
                <Setter Property="FontFamily"           Value="DancingScript"/>
                <Setter Property="TextColor"            Value="{StaticResource AccentGold}"/>
                <Setter Property="FontSize"             Value="36"/>
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
            </Style>

            <!-- Estilo para textos de estadística -->
            <Style x:Key="StatValueStyle" TargetType="Label">
                <Setter Property="FontFamily"           Value="PlayfairDisplay-Bold"/>
                <Setter Property="FontSize"             Value="18"/>
                <Setter Property="TextColor"            Value="{StaticResource AccentGold}"/>
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
            </Style>

            <!-- Estilo para etiquetas de estadística -->
            <Style x:Key="StatLabelStyle" TargetType="Label">
                <Setter Property="FontFamily"           Value="Lato"/>
                <Setter Property="FontSize"             Value="9"/>
                <Setter Property="TextColor"            Value="{StaticResource TextOnDark}"/>
                <Setter Property="Opacity"              Value="0.6"/>
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
                <Setter Property="CharacterSpacing"     Value="1"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>